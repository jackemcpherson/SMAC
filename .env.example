# Example environment variables for SMAC
# Copy this file to .env and fill in actual values if needed

# API Configuration (if additional financial data APIs are added in the future)
# API_KEY=your_api_key_here
# API_BASE_URL=https://api.example.com

# Logging Configuration
# LOG_LEVEL=INFO
# LOG_FILE=logs/smac.log

# Data Storage (if data caching is implemented)
# DATA_CACHE_DIR=data/cache
# CACHE_EXPIRY_HOURS=24